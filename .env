# URL de conexão com o banco de dados (SQLite local por padrão)
DATABASE_URL=sqlite:///./quiz.db

# Configurações para demonstração visual de testes E2E com Playwright
# 1 = Exibe o navegador aberto na tela durante os testes; 0 = Modo invisível/headless
HEADED=0

# Delay em milissegundos a cada ação do robô no teste E2E
# Exemplo: 1000 adiciona 1 segundo de atraso entre digitar, clicar e navegar
SLOW_MO=0
